# Railway Environment Variables
# DO NOT COMMIT THIS FILE TO GIT!

# Spring Profile
SPRING_PROFILES_ACTIVE=railway

# Server Port
PORT=8080

# JWT Secret (Generate with: openssl rand -base64 64)
JWT_SECRET=change-this-to-your-secure-random-string

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend URL
FRONTEND_URL=https://your-frontend-domain.com
OAUTH2_AUTHORIZED_REDIRECT_URI=https://your-frontend-domain.com/auth/success
OAUTH2_ALLOWED_REDIRECT_URIS=https://your-frontend-domain.com/auth/success,https://your-frontend-domain.com/auth/callback

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=denxb3y4a
CLOUDINARY_API_KEY=836246288911529
CLOUDINARY_API_SECRET=Ln8TD2E2x6iRxil-8-PYde3fcOA

# CORS (comma-separated list)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:3000

# Optional JWT format setting (plain|base64|base64url|auto)
JWT_SECRET_FORMAT=plain

# Database (Railway auto-sets this when you add PostgreSQL)
# DATABASE_URL=postgresql://... (auto-generated by Railway)
