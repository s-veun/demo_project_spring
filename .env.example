# Google Cloud Configuration
PROJECT_ID=your-project-id
REGION=us-central1

# Database Configuration (Cloud SQL)
DATABASE_URL=jdbc:postgresql://cloudsql/ecommerce_db
DB_USERNAME=appuser
DB_PASSWORD=your-secure-password

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# JWT Configuration
JWT_SECRET=generate-a-secure-random-string-here

# Google OAuth2 Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FRONTEND_URL=http://localhost:3000
OAUTH2_AUTHORIZED_REDIRECT_URI=http://localhost:3000/auth/success
OAUTH2_ALLOWED_REDIRECT_URIS=http://localhost:3000/auth/success,http://localhost:3000/auth/callback

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Cloud SQL Instance Connection
CLOUD_SQL_INSTANCE=your-project-id:us-central1:ecommerce-db
