{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "java $JAVA_OPTS -Dspring.profiles.active=${SPRING_PROFILES_ACTIVE:-railway} -Dserver.port=${PORT:-8080} -jar build/libs/app.jar",
    "healthcheckPath": "/actuator/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}