# ════════════════════════════════════════════════════════════════════════════
# Environment Configuration Template
# ════════════════════════════════════════════════════════════════════════════
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.template .env
# 2. Fill in all values marked with [REQUIRED]
# 3. Optional values have defaults and can be left empty
# 4. Do NOT commit .env to git (add to .gitignore)
# 5. For production, use Railway environment variables
# 
# IMPORTANT: This file contains sensitive information. Never share it.
# ════════════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────────────
# 🗄️  DATABASE CONFIGURATION [REQUIRED - Change these!]
# ────────────────────────────────────────────────────────────────────────────
# 
# LOCAL DEVELOPMENT:
#   SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ecommerce_db?sslmode=disable
#
# DOCKER DEVELOPMENT:
#   SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ecommerce_db?sslmode=disable
#
# PRODUCTION (Railway):
#   SPRING_DATASOURCE_URL=jdbc:postgresql://shortline.proxy.rlwy.net:13895/railway?sslmode=require
#
# IMPORTANT: Use sslmode=disable for local development, sslmode=require for production
# ────────────────────────────────────────────────────────────────────────────

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ecommerce_db?sslmode=disable
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
spring.datasource.driver-class-name=org.postgresql.Driver

# ────────────────────────────────────────────────────────────────────────────
# 🔧 JPA / HIBERNATE CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
# 
# DDL-AUTO options:
#   create        - Drop and recreate tables on every startup (TESTING ONLY)
#   create-drop   - Create on startup, drop on shutdown (TESTING)
#   update        - Modify existing tables (DEVELOPMENT - default)
#   validate      - Only validate schema, don't modify (PRODUCTION)
#   none          - Do nothing (PRODUCTION with manual migrations)
# ────────────────────────────────────────────────────────────────────────────

SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_FORMAT_SQL=false

# ────────────────────────────────────────────────────────────────────────────
# 🔐 JWT AUTHENTICATION [REQUIRED - Generate new for production!]
# ────────────────────────────────────────────────────────────────────────────
# 
# JWT_SECRET: Generate using:
#   Linux/Mac: openssl rand -base64 64
#   Or use: java -cp . java.util.Base64.getEncoder().encodeToString("your-secret-key".getBytes())
# 
# EXPIRATION in milliseconds:
#   86400000    = 24 hours (access token)
#   604800000   = 7 days (refresh token)
#   2592000000  = 30 days
# ────────────────────────────────────────────────────────────────────────────

JWT_SECRET=your-super-secret-jwt-key-min-64-chars-change-in-production-xxxxxxxxxxxxx
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ────────────────────────────────────────────────────────────────────────────
# 🔗 GOOGLE OAUTH2 CONFIGURATION (Optional - For OAuth2 Login)
# ────────────────────────────────────────────────────────────────────────────
# 
# Get credentials from: https://console.cloud.google.com
# 1. Create OAuth 2.0 credentials (Web application)
# 2. Add authorized redirect URIs:
#    - http://localhost:8080/login/oauth2/code/google (local dev)
#    - https://yourdomain.com/login/oauth2/code/google (production)
# 3. Copy Client ID and Secret below
# ────────────────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ────────────────────────────────────────────────────────────────────────────
# 🖼️  CLOUDINARY CONFIGURATION (Optional - For Image Upload)
# ────────────────────────────────────────────────────────────────────────────
# 
# Get credentials from: https://cloudinary.com
# 1. Sign up for free account
# 2. Go to Dashboard and copy your credentials
# ────────────────────────────────────────────────────────────────────────────

CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ────────────────────────────────────────────────────────────────────────────
# 🌐 FRONTEND / CORS CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
# 
# Frontend URLs for OAuth2 redirects and CORS
# Multiple URLs can be comma-separated
# ────────────────────────────────────────────────────────────────────────────

FRONTEND_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
OAUTH2_AUTHORIZED_REDIRECT_URI=http://localhost:3000/auth/callback
OAUTH2_ALLOWED_REDIRECT_URIS=http://localhost:3000

# CORS configuration (comma-separated list of allowed origins)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ────────────────────────────────────────────────────────────────────────────
# 🏢 ADMIN BOOTSTRAP CONFIGURATION (Optional - Initial Admin Account)
# ────────────────────────────────────────────────────────────────────────────
# 
# Used on first startup to create the initial admin account
# Leave empty to skip admin creation
# Once admin account is created, these values are no longer used
# ────────────────────────────────────────────────────────────────────────────

ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-this-password-on-first-login

# ────────────────────────────────────────────────────────────────────────────
# 📊 LOGGING CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
# 
# Log levels: OFF, FATAL, ERROR, WARN, INFO, DEBUG, TRACE
# Default: INFO (recommended for production)
# DEBUG: Use during development to troubleshoot issues
# TRACE: Very verbose, only for deep debugging
# ────────────────────────────────────────────────────────────────────────────

LOG_LEVEL_ROOT=INFO
LOG_LEVEL_JWT=DEBUG
LOG_LEVEL_SPRING_SECURITY=INFO
LOG_LEVEL_SPRING_SECURITY_OAUTH2=INFO
LOG_LEVEL_HIBERNATE_SQL=INFO
LOG_LEVEL_HIKARI=INFO
LOG_LEVEL_POSTGRES_DRIVER=INFO

# ────────────────────────────────────────────────────────────────────────────
# 🔌 HIKARICP CONNECTION POOL CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
# 
# Performance tuning for database connections
# 
# DEVELOPMENT (High responsiveness):
#   maximum-pool-size: 10-20
#   minimum-idle: 5
#
# PRODUCTION (Resource efficient):
#   maximum-pool-size: 5-10
#   minimum-idle: 1-2
#
# Timeouts in milliseconds:
#   connection-timeout: 30000 (wait 30s for connection from pool)
#   idle-timeout: 600000 (close idle connections after 10 min)
#   max-lifetime: 1800000 (connections live max 30 min)
# ────────────────────────────────────────────────────────────────────────────

HIKARI_MAX_POOL_SIZE=10
HIKARI_MIN_IDLE=5
HIKARI_CONN_TIMEOUT=30000
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000

# ────────────────────────────────────────────────────────────────────────────
# 🗂️  FILE UPLOAD CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
# 
# Upload directories and size limits (in bytes)
# Max file sizes: 
#   5242880 = 5 MB (default for profile images)
#   10485760 = 10 MB
#   52428800 = 50 MB
# ────────────────────────────────────────────────────────────────────────────

BANNER_UPLOAD_DIR=uploads/banners
PROFILE_IMAGE_UPLOAD_DIR=uploads/profile-images
PROFILE_IMAGE_PUBLIC_BASE_PATH=/uploads/profile-images
PROFILE_IMAGE_STORAGE_PROVIDER=cloudinary
PROFILE_IMAGE_CLOUDINARY_FOLDER=uploads/profile-images
PROFILE_IMAGE_MAX_BYTES=5242880

# ────────────────────────────────────────────────────────────────────────────
# 📍 RATE LIMITING CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
# 
# Rate limits per service
# Example: 10 requests per 60 seconds
# ────────────────────────────────────────────────────────────────────────────

PROFILE_IMAGE_RATE_LIMIT_MAX_REQUESTS=10
PROFILE_IMAGE_RATE_LIMIT_WINDOW_SECONDS=60

ADMIN_RATE_LIMIT_MAX_REQUESTS=120
ADMIN_RATE_LIMIT_WINDOW_SECONDS=60

# ────────────────────────────────────────────────────────────────────────────
# ⚙️  APPLICATION CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────

# Server Port
PORT=8080

# Spring Profiles Active (comma-separated: default, dev, prod, railway)
SPRING_PROFILES_ACTIVE=default

# Cache Type (simple, redis, none)
SPRING_CACHE_TYPE=simple

# Redis Configuration (if using Redis for caching)
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=

# ────────────────────────────────────────────────────────────────────────────
# 🚀 RAILWAY-SPECIFIC CONFIGURATION (Uncomment when deploying to Railway)
# ────────────────────────────────────────────────────────────────────────────

# SPRING_DATASOURCE_URL=jdbc:postgresql://shortline.proxy.rlwy.net:13895/railway?sslmode=require&connectTimeout=60
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=your-railway-password
# SPRING_JPA_HIBERNATE_DDL_AUTO=validate
# LOG_LEVEL_ROOT=WARN
# SPRING_CACHE_TYPE=redis

# ════════════════════════════════════════════════════════════════════════════
# END OF CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════
